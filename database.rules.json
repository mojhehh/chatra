    ,
    "mentions": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        "$msgId": {
          ".write": "auth != null && (auth.uid === newData.child('sourceUid').val() || root.child('admins').child(auth.uid).exists())",
          ".validate": "newData.hasChildren(['sourceUid','sourceUsername','messageId','time']) && newData.child('sourceUid').isString() && newData.child('sourceUsername').isString() && newData.child('messageId').isString() && newData.child('time').isNumber() && (!newData.child('messageText').exists() || newData.child('messageText').isString())"
        }
      }
    }

    ,
    "userHelpLastSubmission": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.isNumber()"
      }
    }
    ,
    "userHelpLastAppeal": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.isNumber()"
      }
    }
    ,
    "anonHelpLastSubmission": {
      "$clientId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "newData.isNumber()",
        ".validate": "newData.isNumber() && newData.val() === now"
      }
    }
    ,
    "anonHelpLastAppeal": {
      "$clientId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "newData.isNumber()",
        ".validate": "newData.isNumber() && newData.val() === now"
      }
    }
    ,
    "bannedFingerprints": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
      "$fpHash": {
        ".validate": "!newData.exists() || (newData.hasChildren(['reason','timestamp','bannedBy']) && newData.child('reason').isString() && newData.child('timestamp').isNumber() && newData.child('bannedBy').isString())"
      }
    },
    "auditLog": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      "fingerprintBans": {
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
        "$entryId": {
          ".validate": "newData.hasChildren(['action','fpHash','adminUid','timestamp']) && newData.child('action').isString() && newData.child('fpHash').isString() && newData.child('adminUid').isString() && newData.child('timestamp').isNumber()"
        }
      }
    }
  }
}
