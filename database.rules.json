      "$groupId": {
        ".write": "auth != null && !root.child('bannedUsers').child(auth.uid).exists() && (!data.exists() || data.child('owner').val() === auth.uid || root.child('admins').child(auth.uid).exists() || data.child('groupAdmins').child(auth.uid).val() === true)",
        ".validate": "newData.hasChildren(['name', 'owner', 'createdAt'])",
        "name": { 
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50" 
        },
        "description": { 
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 200)" 
        },
        "owner": { 
          ".validate": "newData.isString() && (!data.exists() ? newData.val() === auth.uid : (data.val() === auth.uid || root.child('admins').child(auth.uid).exists()))"
        },
        "ownerUsername": { 
          ".validate": "!newData.exists() || newData.isString()" 
        },
        "createdAt": { 
          ".validate": "newData.isNumber() || newData.child('.sv').exists()" 
        },
        "isPublic": { 
          ".validate": "!newData.exists() || newData.isBoolean()" 
        },
        "inviteCode": { 
          ".validate": "!newData.exists() || newData.isString()" 
        },
        "maxMembers": { 
          ".validate": "!newData.exists() || newData.isNumber()" 
        },
        "memberCount": {
          ".write": "auth != null && !root.child('bannedUsers').child(auth.uid).exists()",
          ".validate": "!newData.exists() || newData.isNumber()" 
        },
        "photo": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "groupAdmins": {
          "$uid": {
            ".validate": "!newData.exists() || newData.isBoolean()"
          }
        },
        "members": {
          "$uid": {
            ".write": "auth != null && !root.child('bannedUsers').child(auth.uid).exists() && ($uid === auth.uid || data.parent().parent().child('owner').val() === auth.uid || data.parent().parent().child('groupAdmins').child(auth.uid).val() === true || root.child('admins').child(auth.uid).exists())",
            ".validate": "!newData.exists() || newData.isBoolean() || (newData.hasChild('joinedAt') && (newData.child('joinedAt').isNumber() || newData.child('joinedAt').child('.sv').exists()))"
          }
        },
        "messages": {
          ".indexOn": ["time"],
          "$msgId": {
            ".write": "auth != null && !root.child('bannedUsers').child(auth.uid).exists() && data.parent().parent().child('members').child(auth.uid).exists()",
            ".validate": "!newData.exists() || (newData.hasChildren(['fromUid','text','time']) && newData.child('fromUid').isString() && (newData.child('fromUid').val() === auth.uid || newData.child('fromUid').val() === 'system' || newData.child('fromUid').val() === 'aEY7gNeuGcfBErxOHNEQYFzvhpp2') && newData.child('text').isString() && newData.child('text').val().length <= 2000 && (newData.child('time').isNumber() || newData.child('time').child('.sv').exists()))"
          }
        }
      }
    }
  }
}
